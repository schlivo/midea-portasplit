# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Midea PortaSplit (local LAN) ---
# Get TOKEN/KEY once via:  uv run msmart-ng discover --region DE <device-ip>
MIDEA_HOST=192.168.1.50
MIDEA_PORT=6444
MIDEA_DEVICE_ID=000000000000000
MIDEA_TOKEN=
MIDEA_KEY=

# --- Home location (for Open-Meteo true-ambient) ---
HOME_LAT=48.85
HOME_LON=2.35

# --- Netatmo (cloud OAuth2, Energy/thermostat) ---
# Create an app at dev.netatmo.com -> client id/secret; get refresh token via netatmo_auth.py
NETATMO_CLIENT_ID=
NETATMO_CLIENT_SECRET=
NETATMO_REFRESH_TOKEN=
NETATMO_TARGET_ROOM=Living room

# --- Enedis electricity data (OPTIONAL — depends on your setup) ---
# Only if you use the conso.py / Conso API path (conso.boris.sh). Skip otherwise.
CONSO_TOKEN=
CONSO_PRM=00000000000000
